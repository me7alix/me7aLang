import "std.m7"

fn bubble_sort(arr: *int, cnt: uptr) {
	while true {
		change := false
		for i: uptr = 0; i < cnt - 1; i+=1 {
			if arr[i] > arr[i + 1] {
				tmp := arr[i]
				arr[i] = arr[i + 1]
				arr[i + 1] = tmp
				change = true
			}
		}

		if !change then
			break
	}
}

arr: []int = {
	20, 2, 0, 23,
	8, 153,  110,
	2410, 56, 78,
};

fn main() {
	bubble_sort(arr, arr_len(arr))
	for i: uptr = 0; i < 10; i+=1 then
		printf("%zi: %d\n", i, arr[i])
}
