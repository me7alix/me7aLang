import "std.m7"

struct Address {
	city:      *i8
	post_code: int

	fn print(a: int) {
		printf("%s [%d]\n", self.city, self.post_code)
	}
}

struct Person {
	name:   *i8
	salary: int
	addr:   Address

	fn print() {
		printf(
			"Name: %s\nSalary: %d\n",
			self.name, self.salary,
		)

		printf("Address: ")
		self.addr.print(3)
	}
}

fn main() {
	me: Person
	me.name = "Michael"
	me.salary = 777
	me.addr.city = "New York"
	me.addr.post_code = 100101
	me.print()
}
