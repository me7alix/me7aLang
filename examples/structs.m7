import "std/libc.m7"

struct Address {
	city:      *u8
	post_code: int

	fn print() {
		printf(
			"%s [%d]\n",
			self.city,
			self.post_code,
		)
	}
}

struct Person {
	name:   *u8
	salary: int
	addr:   Address

	fn print() {
		printf(
			"Name: %s\n" "Salary: %d\n",
			self.name,
			self.salary,
		)

		printf("Address: ")
		self.addr.print()
	}
}

fn main() {
	me: Person
	me.name = "Michael"
	me.salary = 777
	me.addr.city = "New York"
	me.addr.post_code = 100101
	me.print()
}
