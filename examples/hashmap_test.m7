import "std/hashmap.m7"

DeclHashMap(HashMapStrInt, *u8, int)

fn HashMapStrInt_compare(a: *u8, b: *u8): int  {
	return strcmp(a, b)
}

fn HashMapStrInt_hashf(str: *u8): u32 {
	return hash_str(str);
}

fn main() {
	hm: HashMapStrInt
	hm.add("ten",    10)
	hm.add("twenty", 20)

	printf("one: %p\n", hm.get("one"))

	ht_foreach_node (node, hm, {
		printf("%s\t%d\n", node.key, node.val)
	})
}
