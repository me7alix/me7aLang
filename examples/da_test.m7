import "da.m7"

DeclDynArray(Numbers, int)

fn main() {
	nums: Numbers

	nums.append(10)
	nums.append(3)
	nums.append(5)

	nums.remove_ordered(1:uptr)

	printf("count: %zu\n", nums.count)
	printf("capacity: %zu\n\n", nums.capacity)
	printf("first: %d\n", nums.first())
	printf("last: %d\n", nums.last())

	nums.free()
}
